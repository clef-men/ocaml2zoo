From zoo Require Import
  prelude.
From zoo.language Require Import
  typeclasses
  notations.
From tests Require Import
  proph__types.
From zoo Require Import
  options.

Definition proph٠test1 : val :=
  fun: <> =>
    let: "proph" := Proph in
    Resolve (1 + 1) "proph" ().

Definition proph٠test2 : val :=
  fun: <> =>
    let: "proph" := Proph in
    Resolve Skip "proph" ().

Definition proph٠test3 : val :=
  fun: <> =>
    let: "proph" := Proph in
    let: "@tmp" := () in
    Resolve Skip "proph" "@tmp" ;;
    "@tmp".
